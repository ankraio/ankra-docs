{
  "name": "ankra-docs",
  "private": true,
  "description": "Ankra platform documentation (Mintlify)",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "mint dev",
    "check:links": "mint broken-links",
    "check:nav": "python3 scripts/check_nav.py",
    "check:frontmatter": "python3 scripts/check_frontmatter.py",
    "check:snippets": "python3 scripts/check_snippets.py",
    "check": "pnpm run check:nav && pnpm run check:frontmatter && pnpm run check:snippets && pnpm run check:links"
  },
  "devDependencies": {
    "mint": "^4.2.666"
  }
}
